{
  "name": "create-nitro-app",
  "version": "0.8.4",
  "description": "Create a Nitro app with a single command",
  "license": "MIT",
  "repository": "nitrojs/create-nitro-app",
  "bin": "./dist/cli.mjs",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "obuild",
    "create-nitro-app": "node ./src/cli.ts",
    "lint": "oxlint . && oxfmt --check .",
    "fmt": "automd && oxlint . --fix && oxfmt .",
    "prepack": "pnpm build",
    "release": "pnpm test && changelogen --release && npm publish && git push --follow-tags",
    "test": "pnpm lint && pnpm test:types",
    "test:types": "tsgo --noEmit --skipLibCheck"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "^7.0.0-dev.20260326.1",
    "automd": "^0.4.3",
    "changelogen": "^0.6.2",
    "citty": "^0.2.1",
    "consola": "^3.4.2",
    "eslint-config-unjs": "^0.6.2",
    "giget": "^3.1.2",
    "nypm": "^0.6.5",
    "obuild": "^0.4.32",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tinyexec": "^1.0.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "packageManager": "pnpm@10.33.0"
}
